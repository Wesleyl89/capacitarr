# Nuxt dev/build outputs
.output
.nuxt
.data
.nitro
.cache
dist

# Node dependencies
node_modules

# Logs
logs
*.log

# Environment variables
.env
.env.*
!.env.example

# IDE
.vscode
*.sw?

# Synced docs (generated at build time)
content/docs/*.md
content/docs/api/*.md
!content/docs/.gitkeep

# Generated screenshot artifacts (PNGs synced from ../screenshots/ are ignored;
# lossless WebP files in public/screenshots/ are tracked as permanent assets)
public/screenshots/*.png
public/screenshots/*.jpg

# Build-time generated repo stats
app/repo-stats.json

# Preview directory
.preview
